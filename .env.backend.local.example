# Backend only (local machine running Python + DB)
API_KEY=4a00372e2f061de230a70ef8303411ff
# Include your deployed Vercel domain (and custom domain if used).
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173,http://127.0.0.1:5173
# Optional: allow Vercel deployment domains (preview/prod) and ngrok origins.
CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.vercel\.app|[a-z0-9-]+\.ngrok-free\.(app|dev))$

# Keep capture/metadata responsive
AICAM_CAPTURE_BUFFER=1
AICAM_WS_MAX_CLIENTS=64
AICAM_WS_HEARTBEAT_SEC=10

# Optional MJPEG fallback tuning (used only if frontend allows backend video fallback)
AICAM_ENABLE_FRAME_STREAMING=1
AICAM_MJPEG_FPS=30
AICAM_MJPEG_QUALITY=60
AICAM_MJPEG_QUALITY_MIN=35
AICAM_WSJPEG_ADAPTIVE=1
AICAM_WSJPEG_MIN_FPS=6
AICAM_WSJPEG_QUALITY_STEP=5
AICAM_WSJPEG_SLOW_SEND_MS=90
AICAM_WSJPEG_FAST_SEND_MS=25
AICAM_MJPEG_MAX_CLIENTS=8
# Janus upstream for backend /janus reverse proxy (single-tunnel mode).
AICAM_JANUS_UPSTREAM=http://127.0.0.1:8088/janus

# Optional ONNXRuntime detector tuning.
# AICAM_ORT_INTRA_THREADS=3
# AICAM_ORT_INTER_THREADS=1
# AICAM_ORT_EXECUTION_MODE=sequential
# AICAM_ORT_GRAPH_OPT_LEVEL=all
# AICAM_ORT_ENABLE_MEM_PATTERN=1
# AICAM_ORT_ENABLE_CPU_MEM_ARENA=1
# AICAM_ORT_INTRA_SPIN=1
# AICAM_ORT_INTER_SPIN=1
