# Frontend (Vite)
# Split deployment mode: Vercel serves UI; browser connects to backend + Janus endpoints.
VITE_API_BASE=https://api.your-domain.example.com
VITE_API_KEY=4a00372e2f061de230a70ef8303411ff
VITE_WS_METADATA_URL=
VITE_JANUS_HTTP_URL=https://janus-api.your-domain.example.com/janus
VITE_JANUS_WS_URL=
VITE_JANUS_MOUNTPOINT=1
VITE_DISABLE_BACKEND_VIDEO=true
VITE_DISABLE_JANUS=false
VITE_METADATA_LATEST_URL=
VITE_METADATA_POLL_MS=250
VITE_USE_MOCK=0
VITE_DISABLE_WEBRTC=false
VITE_VIDEO_PRIMARY_TRANSPORT=janus
VITE_VIDEO_FALLBACK_TRANSPORT=none
VITE_JANUS_FIRST_TRACK_TIMEOUT_MS=15000
VITE_WSJPEG_FPS_LOCAL=20
VITE_WSJPEG_FPS_REMOTE=10
VITE_WSJPEG_ADAPTIVE=1
# Optional client-side render cap (0 = uncapped / no hard throttle)
VITE_WSJPEG_RENDER_MAX_FPS=0

# Backend (FastAPI)
API_KEY=
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.vercel\.app|[a-z0-9-]+\.ngrok-free\.(app|dev))$
AICAM_STATIC_PATH=.
# Set to 1 to re-enable WS-JPEG/MJPEG fallback.
AICAM_ENABLE_FRAME_STREAMING=0
AICAM_MJPEG_FPS=30
AICAM_MJPEG_QUALITY=60
AICAM_MJPEG_QUALITY_MIN=35
AICAM_WSJPEG_ADAPTIVE=1
AICAM_WSJPEG_MIN_FPS=6
AICAM_WSJPEG_QUALITY_STEP=5
AICAM_WSJPEG_SLOW_SEND_MS=90
AICAM_WSJPEG_FAST_SEND_MS=25
AICAM_MJPEG_MAX_CLIENTS=8
AICAM_WS_MAX_CLIENTS=64
AICAM_JANUS_UPSTREAM=http://127.0.0.1:8088/janus
# Optional ONNXRuntime detector tuning.
# AICAM_ORT_INTRA_THREADS=3
# AICAM_ORT_INTER_THREADS=1
# AICAM_ORT_EXECUTION_MODE=sequential
# AICAM_ORT_GRAPH_OPT_LEVEL=all
# AICAM_ORT_ENABLE_MEM_PATTERN=1
# AICAM_ORT_ENABLE_CPU_MEM_ARENA=1
# AICAM_ORT_INTRA_SPIN=1
# AICAM_ORT_INTER_SPIN=1

# Janus ingest relay (optional docker profile: ingest)
JANUS_RTSP_URL=rtsp://USER:PASS@CAMERA_IP:554/your-path

# Split deployment example values:
# VITE_API_BASE=https://your-public-backend.example.com
# VITE_WS_METADATA_URL=wss://your-public-backend.example.com/api/realtime/ws
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173,http://127.0.0.1:5173
# CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.vercel\.app|[a-z0-9-]+\.ngrok-free\.(app|dev))$
