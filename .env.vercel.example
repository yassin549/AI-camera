# Frontend only (set these in Vercel project env settings)
# Split deployment mode: Vercel serves UI only.
VITE_API_BASE=https://api.your-domain.example.com
VITE_API_KEY=4a00372e2f061de230a70ef8303411ff

# Metadata transport (leave unset to auto-derive from VITE_API_BASE)
VITE_WS_METADATA_URL=
VITE_METADATA_LATEST_URL=
VITE_METADATA_POLL_MS=250

# Janus signaling endpoint (browser receives media directly from Janus ICE candidates).
VITE_JANUS_HTTP_URL=https://janus-api.your-domain.example.com/janus
VITE_JANUS_MOUNTPOINT=1
VITE_DISABLE_JANUS=false

# Keep backend video enabled only for degraded fallback.
VITE_DISABLE_BACKEND_VIDEO=false
VITE_DISABLE_WEBRTC=false

# Deterministic production transport plan: one primary + one degraded fallback.
VITE_VIDEO_PRIMARY_TRANSPORT=janus
VITE_VIDEO_FALLBACK_TRANSPORT=wsjpeg
