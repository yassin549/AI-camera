      "op": "<=",
      "value": 800.0,
      "unit": "ms"
    },
    {
      "name": "metadata_freshness_ms_max",
      "source": "manual",
      "metric": "metadata_freshness_ms",
      "op": "<=",
      "value": 250.0,
      "unit": "ms"
    },
    {
      "name": "identity_thumbnail_load_ms_max",
      "source": "manual",
      "metric": "identity_thumbnail_load_ms",
      "op": "<=",
      "value": 500.0,
      "unit": "ms"
    }
  ]
